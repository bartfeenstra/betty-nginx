#!/usr/bin/env bash

set -Eeuo pipefail

cd "$(dirname "$0")/.."

pybabel extract -F ./babel.ini -o ./betty_nginx/assets/betty_nginx.pot --project 'Nginx for Betty' --copyright-holder 'Bart Feenstra & contributors' ./betty_nginx

mkdir -p ./assets/locale
while read -r locale_directory_path; do
  locale=$(basename "$locale_directory_path")
  pybabel update -d ./betty_nginx/assets/locale -l "$locale" -D betty_nginx -i ./betty_nginx/assets/betty_nginx.pot
done < <(find ./assets/locale/ -mindepth 1 -maxdepth 1 -type d)