#!/usr/bin/env bash

set -Eeuo pipefail

cd "$(dirname "$0")/.."

# Lint the shell scripts.
for file in ./bin/*; do
    shellcheck -x "$file"
done

# Test the Python code style.
flake8 --config ./flake8.ini ./betty_nginx
mypy

# Run Python tests with coverage.
coverage erase
PYTHONWARNINGS='error:::betty_nginx[.*]' coverage run --append -m pytest
coverage report -m
