#: betty_nginx/__init__.py:58
msgid "Generate <a href=\"https://nginx.org/\">nginx</a> configuration for your site, as well as a <code>Dockerfile</code> to build a <a href=\"https://www.docker.com/\">Docker</a> container around it."
msgstr "Genereer <a href=\"https://nginx.org/\">nginx</a>-configuratie voor je site, evenals een <code>Dockerfile</code> om een <a href=\"https://www.docker.com/\">Docker</a>-container mee te bouwen."

#: betty_nginx/config.py:21
msgid "Nginx configuration must be a mapping (dictionary)."
msgstr "Nginx-configuratie moet een mapping (dictionary) zijn."

#: betty_nginx/config.py:26
msgid "The WWW directory must be a string or left empty."
msgstr "De WWW-map moet een tekenreeks zijn, of moet leeg worden gelaten."

#: betty_nginx/config.py:32
msgid "HTTPS must be a boolean or left empty."
msgstr "HTTPS moet een boolean zijn, of moet leeg worden gelaten."

